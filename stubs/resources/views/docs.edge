<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LaraNode Documentation</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #F05340;
            --bg-dark: #0f172a;
            --bg-card: #1e293b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --glass-bg: rgba(30, 41, 59, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --sidebar-width: 280px;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            line-height: 1.6;
            display: flex;
            min-height: 100vh;
        }
        aside {
            width: var(--sidebar-width);
            background: rgba(15, 23, 42, 0.95);
            border-right: 1px solid var(--glass-border);
            height: 100vh;
            position: sticky;
            top: 0;
            padding: 2rem;
            overflow-y: auto;
        }
        .logo { font-size: 1.5rem; font-weight: 800; margin-bottom: 2rem; }
        .logo span { color: var(--primary); }
        nav h3 { font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); margin: 1.5rem 0 0.5rem; letter-spacing: 1px; }
        nav ul { list-style: none; }
        nav a { display: block; padding: 0.5rem 0; color: #cbd5e1; text-decoration: none; font-size: 0.95rem; transition: color 0.2s; }
        nav a:hover { color: var(--primary); }
        nav a.active { color: var(--primary); font-weight: 600; }

        main { flex: 1; padding: 4rem 6rem; max-width: 1000px; margin: 0 auto; }
        section { margin-bottom: 6rem; scroll-margin-top: 4rem; }
        h1 { font-size: 3rem; margin-bottom: 1.5rem; font-weight: 800; border-bottom: 1px solid var(--glass-border); padding-bottom: 1rem; }
        h2 { font-size: 2rem; margin: 3rem 0 1rem; color: var(--primary); font-weight: 700; }
        h3 { font-size: 1.25rem; margin: 2rem 0 1rem; color: #fff; }
        p { margin-bottom: 1.5rem; color: #cbd5e1; font-size: 1.1rem; }
        pre {
            background: #000;
            padding: 1.5rem;
            border-radius: 0.75rem;
            overflow-x: auto;
            margin: 1.5rem 0;
            border: 1px solid var(--glass-border);
        }
        code { font-family: 'Fira Code', monospace; font-size: 0.9rem; color: #e2e8f0; }
        .highlight { color: var(--primary); font-weight: 600; }

        .feature-card h4 { margin-bottom: 0.5rem; color: #fff; }
        .feature-card p { font-size: 0.95rem; margin-bottom: 0; }

        .rule-card {
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid var(--glass-border);
            border-radius: 0.75rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
            scroll-margin-top: 5rem;
        }
        .rule-card h4 {
            color: var(--primary);
            font-family: 'Fira Code', monospace;
            font-size: 1.2rem;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
        }
        .rule-card h4::before {
            content: '#';
            margin-right: 0.5rem;
            opacity: 0.5;
        }
        .rule-card .meta {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        @media (max-width: 1000px) {
            aside { display: none; }
            main { padding: 2rem; }
        }
    </style>
</head>
<body>
    <aside>
        <div class="logo">Lara<span>Node</span></div>
        <nav>
            <h3>Getting Started</h3>
            <ul>
                <li><a href="#introduction">Introduction</a></li>
                <li><a href="#installation">Installation</a></li>
            </ul>
